<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".MainApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="Tanuki"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- OAuth redirect: dev.tanuki://oauth-callback -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="dev.tanuki"
                    android:host="oauth-callback" />
            </intent-filter>

            <!-- Open shared GitLab merge-request links in Tanuki, e.g.
                 https://gitlab.com/<group>/<project>/-/merge_requests/199
                 Android's path glob is greedy without backtracking, so a single "/.*/-/..."
                 never matches. Instead we match each path segment with [^/]+ (which can't
                 cross a slash, so it stops on its own) for the realistic range of project
                 nesting depths (2 = group/project, up to 6 for deep subgroups). -->
            <intent-filter android:label="Open in Tanuki">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="gitlab.com" />
                <data android:scheme="http" android:host="gitlab.com" />
                <data android:pathAdvancedPattern="/[^/]+/[^/]+/-/merge_requests/[0-9]+.*" />
                <data android:pathAdvancedPattern="/[^/]+/[^/]+/[^/]+/-/merge_requests/[0-9]+.*" />
                <data android:pathAdvancedPattern="/[^/]+/[^/]+/[^/]+/[^/]+/-/merge_requests/[0-9]+.*" />
                <data android:pathAdvancedPattern="/[^/]+/[^/]+/[^/]+/[^/]+/[^/]+/-/merge_requests/[0-9]+.*" />
                <data android:pathAdvancedPattern="/[^/]+/[^/]+/[^/]+/[^/]+/[^/]+/[^/]+/-/merge_requests/[0-9]+.*" />
            </intent-filter>
        </activity>
    </application>
</manifest>
